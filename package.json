{
  "name": "flaxia-crowd",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "deploy:worker": "npm run deploy --workspace=packages/worker",
    "dev:worker": "npm run dev --workspace=packages/worker",
    "dev:node": "npm run dev --workspace=packages/node",
    "dev:darkshark": "npm run dev --workspace=packages/darkshark",
    "dev:text-analyzer": "npm run dev --workspace=packages/text-analyzer",
    "dev:translation": "npm run dev --workspace=packages/translation"
  }
}
